import cv2
import numpy as np
import matplotlib.pyplot as plt
import os

IMAGE_PATH = "lowlight.jpg"  
OUTPUT_DIR = "output"
CLAHE_CLIP_LIMIT = 2.0
CLAHE_TILE_SIZE = (8, 8)
GAMMA_VALUE = 1.4

os.makedirs(OUTPUT_DIR, exist_ok=True)

# LOAD IMAGE
img = cv2.imread(IMAGE_PATH)
if img is None:
    raise FileNotFoundError("Image not found")

img_rgb = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)

def histogram_equalization(img):
    ycrcb = cv2.cvtColor(img, cv2.COLOR_BGR2YCrCb)
    y, cr, cb = cv2.split(ycrcb)

    y_eq = cv2.equalizeHist(y)
    ycrcb_eq = cv2.merge((y_eq, cr, cb))

    return cv2.cvtColor(ycrcb_eq, cv2.COLOR_YCrCb2BGR)

def clahe_enhancement(img, clip_limit=2.0, tile_grid_size=(8, 8)):
    lab = cv2.cvtColor(img, cv2.COLOR_BGR2LAB)
    l, a, b = cv2.split(lab)

    clahe = cv2.createCLAHE(
        clipLimit=clip_limit,
        tileGridSize=tile_grid_size
    )

    l_clahe = clahe.apply(l)
    lab_clahe = cv2.merge((l_clahe, a, b))

    return cv2.cvtColor(lab_clahe, cv2.COLOR_LAB2BGR)

def gamma_correction(img, gamma=1.4):
    inv_gamma = 1.0 / gamma
    table = np.array([
        ((i / 255.0) ** inv_gamma) * 255
        for i in np.arange(256)
    ]).astype("uint8")

    return cv2.LUT(img, table)

def cega_enhancement(img, clip_limit=2.0, gamma=1.4):
    clahe_img = clahe_enhancement(img, clip_limit)
    gamma_img = gamma_correction(clahe_img, gamma)
    return gamma_img


he_img = histogram_equalization(img)
clahe_img = clahe_enhancement(img, CLAHE_CLIP_LIMIT, CLAHE_TILE_SIZE)
cega_img = cega_enhancement(img, CLAHE_CLIP_LIMIT, GAMMA_VALUE)


cv2.imwrite(os.path.join(OUTPUT_DIR, "original.jpg"), img)
cv2.imwrite(os.path.join(OUTPUT_DIR, "he.jpg"), he_img)
cv2.imwrite(os.path.join(OUTPUT_DIR, "clahe.jpg"), clahe_img)
cv2.imwrite(os.path.join(OUTPUT_DIR, "cega.jpg"), cega_img)


plt.figure(figsize=(14, 6))

plt.subplot(1, 4, 1)
plt.title("Original")
plt.imshow(img_rgb)
plt.axis("off")

plt.subplot(1, 4, 2)
plt.title("HE")
plt.imshow(cv2.cvtColor(he_img, cv2.COLOR_BGR2RGB))
plt.axis("off")

plt.subplot(1, 4, 3)
plt.title("CLAHE")
plt.imshow(cv2.cvtColor(clahe_img, cv2.COLOR_BGR2RGB))
plt.axis("off")

plt.subplot(1, 4, 4)
plt.title("CEGA")
plt.imshow(cv2.cvtColor(cega_img, cv2.COLOR_BGR2RGB))
plt.axis("off")

plt.tight_layout()
plt.show()

print("Results saved", OUTPUT_DIR)

