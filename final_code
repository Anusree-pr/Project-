import cv2
import numpy as np
import tensorflow as tf
import time

from face_recog.face_recognition import FaceRecognition
from face_recog.face_detection_dlib import FaceDetectorDlib
from face_recog.media_utils import convert_to_rgb


def clahe_enhancement(img, clip_limit=2.0, tile_grid_size=(8, 8)):
    lab = cv2.cvtColor(img, cv2.COLOR_BGR2LAB)
    l, a, b = cv2.split(lab)

    clahe = cv2.createCLAHE(
        clipLimit=clip_limit,
        tileGridSize=tile_grid_size
    )

    l_clahe = clahe.apply(l)
    lab_clahe = cv2.merge((l_clahe, a, b))

    return cv2.cvtColor(lab_clahe, cv2.COLOR_LAB2BGR)


def is_low_light(img):
    gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)
    return np.mean(gray) < 80


face_recognizer = FaceRecognition(
    model_loc="models",
    persistent_data_loc="data/facial_data.json",
    face_detector="dlib"
)

face_detector = FaceDetectorDlib()

MODEL_PATH = "detect.tflite"

interpreter = tf.lite.Interpreter(model_path=MODEL_PATH)

input_size = 320

interpreter.resize_tensor_input(
    interpreter.get_input_details()[0]['index'],
    [1, input_size, input_size, 3]
)

interpreter.allocate_tensors()

input_details = interpreter.get_input_details()
output_details = interpreter.get_output_details()

print("[INFO] Models loaded...")


cap = cv2.VideoCapture(0)

prev_time = 0
fps = 0


while True:
    start_time = time.time()

    ret, frame = cap.read()
    if not ret:
        break

    h, w, _ = frame.shape

    img = cv2.resize(frame, (input_size, input_size))
    img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)
    input_data = np.expand_dims(img, axis=0).astype(np.uint8)

    interpreter.set_tensor(input_details[0]['index'], input_data)
    interpreter.invoke()

    boxes = interpreter.get_tensor(output_details[0]['index'])[0]
    scores = interpreter.get_tensor(output_details[3]['index'])[0][:, 1]

    selected_indices = tf.image.non_max_suppression(
        boxes,
        scores,
        max_output_size=5,
        iou_threshold=0.5,
        score_threshold=0.6
    ).numpy()

    for i in selected_indices:
        ymin, xmin, ymax, xmax = boxes[i]

        xmin = int(xmin * w)
        xmax = int(xmax * w)
        ymin = int(ymin * h)
        ymax = int(ymax * h)

        margin = 20
        xmin = max(0, xmin - margin)
        ymin = max(0, ymin - margin)
        xmax = min(w, xmax + margin)
        ymax = min(h, ymax + margin)

        person_crop = frame[ymin:ymax, xmin:xmax]

        if person_crop.size == 0:
            continue

        rgb_crop = convert_to_rgb(person_crop)
        bboxes = face_detector.detect_faces(rgb_crop)

        if len(bboxes) == 0:
            continue

        for bbox in bboxes:
            x1, y1, x2, y2 = bbox

            x1_full = xmin + x1
            y1_full = ymin + y1
            x2_full = xmin + x2
            y2_full = ymin + y2

            face_img = frame[y1_full:y2_full, x1_full:x2_full]

            if face_img.size == 0:
                continue

            if is_low_light(face_img):
                face_img = clahe_enhancement(face_img)

            try:
                matches = face_recognizer.recognize_faces(
                    image=convert_to_rgb(face_img),
                    threshold=0.6
                )
            except Exception:
                continue

            name = "Unknown"
            if matches and matches[0][1] is not None:
                name = matches[0][1]["name"]

            # Draw face box + name
            cv2.rectangle(frame, (x1_full, y1_full), (x2_full, y2_full), (0, 255, 0), 2)
            cv2.putText(frame, name, (x1_full, y1_full - 10),
                        cv2.FONT_HERSHEY_SIMPLEX, 0.6, (0, 255, 0), 2)

        # Draw person box
        cv2.rectangle(frame, (xmin, ymin), (xmax, ymax), (255, 0, 0), 2)

    end_time = time.time()
    curr_fps = 1 / (end_time - start_time)

    fps = 0.9 * fps + 0.1 * curr_fps  # smoothing

    # Display FPS
    cv2.putText(frame, f"FPS: {int(fps)}", (20, 40),
                cv2.FONT_HERSHEY_SIMPLEX, 1, (0, 0, 255), 2)


    cv2.imshow("final", frame)

    if cv2.waitKey(1) & 0xFF == ord('q'):
        break


cap.release()
cv2.destroyAllWindows()
